# Serves the landing site AND the installer downloads from one origin, with
# automatic HTTPS (Let's Encrypt). Because site and files share the domain,
# no CORS is needed — the site fetches /latest.json same-origin.

{
	# ACME contact address; set via the ACME_EMAIL env in docker-compose.
	email {$ACME_EMAIL}
}

{$SITE_DOMAIN:loiiden.de} {
	encode zstd gzip

	# Download manifest — always fresh.
	@manifest path /latest.json
	handle @manifest {
		root * /srv/downloads
		header Cache-Control "public, max-age=60"
		file_server
	}

	# Newest installers — short cache, force download.
	@latest path /latest/*
	handle @latest {
		root * /srv/downloads
		header Cache-Control "public, max-age=60"
		header Content-Disposition attachment
		file_server
	}

	# Versioned archive (/0.1.3/...) — immutable, cache forever.
	@versioned path_regexp version ^/[0-9]
	handle @versioned {
		root * /srv/downloads
		header Cache-Control "public, max-age=31536000, immutable"
		header Content-Disposition attachment
		file_server
	}

	# Everything else is the static site.
	handle {
		root * /srv/site
		try_files {path} /index.html
		file_server
	}
}
